{
  "name": "k-vault",
  "description": "K-Vault - Free File Hosting Service based on Telegram",
  "version": "1.0.0",
  "scripts": {
    "build": "node -e \"console.log('No build step required. For Cloudflare Pages Git integration, leave Build command and Build output directory empty.')\"",
    "ci-test": "concurrently --kill-others --success first \"npm start\" \"wait-on http://localhost:8080 && mocha --exit\"",
    "test": "mocha",
    "start": "npx wrangler pages dev ./ --kv \"img_url\" --r2=R2_BUCKET --compatibility-date=2026-05-03 --port 8080 --persist-to ./data",
    "pages:r2:doctor": "node scripts/cloudflare-pages-r2-doctor.js",
    "pages:deploy": "npx wrangler pages deploy .",
    "docker:init-env": "node scripts/bootstrap-env.js",
    "server:dev": "npm --prefix server run dev",
    "docker:build": "docker build -t k-vault:local .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:doctor": "node scripts/docker-storage-doctor.js",
    "docker:smoke:ci": "node scripts/docker-ci-smoke.js",
    "regression:storage": "node scripts/storage-regression.js"
  },
  "dependencies": {
    "@cloudflare/pages-plugin-sentry": "^1.1.4",
    "@sentry/tracing": "^7.120.4",
    "acorn": "^8.17.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "hono": "^4.12.25",
    "mocha": "^11.7.6",
    "wait-on": "^9.0.10",
    "wrangler": "^4.111.0"
  },
  "overrides": {
    "@babel/runtime": "^7.29.7",
    "axios": "^1.17.0",
    "diff": "^9.0.0",
    "follow-redirects": "^1.16.0",
    "form-data": "^4.0.5",
    "js-yaml": "^4.2.0",
    "lodash": "^4.18.1",
    "serialize-javascript": "^7.0.5"
  }
}
