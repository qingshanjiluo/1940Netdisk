# Runtime
NODE_ENV=production
# Internal API port used by the single Docker image. Keep this at 8787.
PORT=8787
PUBLIC_BASE_URL=

# Admin auth (set both to enable login)
BASIC_USER=admin
BASIC_PASS=change_this_password
SESSION_COOKIE_NAME=k_vault_session
SESSION_DURATION_MS=86400000

# Optional in Docker: if missing or left as placeholders, the container writes
# persistent generated values to /app/data/runtime.env on first start.
CONFIG_ENCRYPTION_KEY=replace_with_a_long_random_secret
SESSION_SECRET=replace_with_another_long_random_secret

# Guest upload policy
GUEST_UPLOAD=false
GUEST_MAX_FILE_SIZE=5242880
GUEST_DAILY_LIMIT=10

# Upload limits
UPLOAD_MAX_SIZE=104857600
UPLOAD_SMALL_FILE_THRESHOLD=20971520
CHUNK_SIZE=5242880

# Data locations in container
DATA_DIR=/app/data
DB_PATH=/app/data/k-vault.db
CHUNK_DIR=/app/data/chunks

# Basic settings storage backend (sqlite | redis)
SETTINGS_STORE=sqlite
# For Upstash/Redis/KVrocks, set a redis:// or rediss:// URL
# Example with local compose profile: redis://redis:6379
SETTINGS_REDIS_URL=
SETTINGS_REDIS_PREFIX=k-vault
SETTINGS_REDIS_CONNECT_TIMEOUT_MS=5000

# Optional bootstrap default storage selection
# Values: telegram | r2 | s3 | discord | huggingface | webdav | github
DEFAULT_STORAGE_TYPE=telegram

# Telegram bootstrap
TG_BOT_TOKEN=
TG_CHAT_ID=
CUSTOM_BOT_API_URL=https://api.telegram.org

# R2 / S3 bootstrap
R2_ENDPOINT=
R2_REGION=auto
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Discord bootstrap
DISCORD_WEBHOOK_URL=
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# HuggingFace bootstrap
HF_TOKEN=
HF_REPO=

# WebDAV bootstrap
WEBDAV_BASE_URL=
WEBDAV_USERNAME=
WEBDAV_PASSWORD=
WEBDAV_BEARER_TOKEN=
WEBDAV_ROOT_PATH=

# GitHub bootstrap
GITHUB_REPO=
GITHUB_TOKEN=
GITHUB_MODE=releases
GITHUB_PREFIX=
GITHUB_RELEASE_TAG=
GITHUB_BRANCH=
GITHUB_API_BASE=https://api.github.com
